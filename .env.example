# EmailJS Configuration — Required for contact and enquiry forms
# Setup: https://www.emailjs.com/
# 1. Create account → Add Email Service (Gmail) → Copy Service ID
# 2. Create Email Template → Copy Template ID
# 3. Account → API Keys → Copy Public Key
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Site URL — Used for SEO canonical URLs and Open Graph tags
# Set to your production domain, no trailing slash
VITE_SITE_URL=https://humedaxivepharma.com

# Google Analytics 4 — Optional, leave blank to disable
# Get Measurement ID from: https://analytics.google.com/
VITE_GA_MEASUREMENT_ID=

# Google Search Console Verification — Optional
# Paste the content value from the GSC meta tag verification here
# Then add: <meta name="google-site-verification" content="%VITE_GSC_VERIFICATION%" /> to index.html
VITE_GSC_VERIFICATION=
